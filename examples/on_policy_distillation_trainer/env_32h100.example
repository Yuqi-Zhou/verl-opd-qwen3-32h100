# 32×H100 OPD — copy to .env.32h100 on the training server and edit

# --- Python / verl (server defaults from prior OPD runs) ---
export PYTHON_BIN=/opt/tiger/verl_envs/v080_qwen35_cu128/bin/python
export VERL_INSTALL_DIR=/opt/tiger/verl-opd-qwen3-32h100
# After git clone, symlink or replace old verl:
#   ln -sfn ${VERL_INSTALL_DIR} /opt/tiger/verl

# --- Models (Qwen3 family, same tokenizer) ---
# TODO: set real checkpoint paths on /mnt/bn/...
export STUDENT_MODEL=/mnt/bn/search-nlp-vagcp/lvjiajun.a/model/Qwen3-30B-A3B
export TEACHER_MODEL=/mnt/bn/search-nlp-vagcp/lvjiajun.a/model/Qwen3-235B-MoE

# --- Data ---
export TRAIN_FILE=/mnt/bn/search-nlp-vagcp/lvjiajun.a/RL/data/opd_train.parquet
export TEST_FILE=/mnt/bn/search-nlp-vagcp/lvjiajun.a/RL/data/opd_test.parquet

# --- Output / logging ---
export CKPT_ROOT=/mnt/bn/search-nlp-vagcp/lvjiajun.a/RL/opd_runs/qwen3_30b_a3b_235b_moe_32h100
export DEFAULT_LOCAL_DIR=${CKPT_ROOT}/checkpoints
export ROLLOUT_DATA_DIR=${CKPT_ROOT}/rollouts
export TENSORBOARD_DIR=${CKPT_ROOT}/tensorboard
export TRAINER_LOGGER='["console","tensorboard","wandb"]'
export SAVE_FREQ=20
export RESUME_MODE=auto

# --- Ray cluster (4 nodes × 8 H100) ---
# export RAY_ADDRESS=ray://head-node:10001

# --- Sequence ---
export MAX_PROMPT=18000
export MAX_RESPONSE=2048

# --- Phase: conservative (smoke) | aggressive (production) ---
export OPD_PHASE=conservative

# --- Optional overrides ---
# export TOTAL_ROLLOUT_STEPS=200000
# export MINI_BATCH=64
# export MICRO_BATCH=1
# export LR=5e-7
# export TEACHER_MAX_BATCHED_TOKENS=8192
# export TEACHER_MAX_SEQS=2
# export GEN_BATCH=4
# export STALENESS=0.5

# --- WandB ---
# export WANDB_PROJECT=verl-opd-qwen3-32h100
# export WANDB_API_KEY=...
